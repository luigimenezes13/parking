{
  "name": "parking",
  "version": "0.0.1",
  "main": "./src/index.js",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "nodemon --watch 'src' --ext 'ts' --ignore './**/*.spec.ts' --exec 'tsx --env-file=.env ./src/infra/server/index.ts'",
    "test": "vitest --coverage --run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --coverage.enabled=true --ui",
    "test:integration": "vitest --config vitest.config.integration.ts --run",
    "test:all": "npm run test && npm run test:integration",
    "test:di": "tsx src/infra/di/test-di.ts",
    "migrate": "npx prisma migrate dev --schema ./src/infra/database/prisma/schema.prisma",
    "migrate:prod": "npx prisma migrate deploy --schema ./src/infra/database/prisma/schema.prisma",
    "build": "tsup src/infra/server/index.ts --format esm --out-dir dist --clean",
    "start": "node --env-file=.env ./dist/index.js",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "studio": "prisma studio --schema ./src/infra/database/prisma/schema.prisma",
    "generate": "prisma generate --schema ./src/infra/database/prisma/schema.prisma",
    "seed": "tsx --env-file=.env ./src/infra/database/seed.ts",
    "pr": "npm run test && npm run lint:fix && npm run typecheck && npm run build"
  },
  "prisma": {
    "schema": "src/infra/database/prisma/schema.prisma"
  },
  "packageManager": "pnpm@10.10.0",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/client": "^7.6.0",
    "@tsconfig/node20": "^20.1.9",
    "fastify": "^5.8.4",
    "inversify": "^8.1.0",
    "kysely": "^0.28.15",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.5.1",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.24",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "prisma-kysely": "^3.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
