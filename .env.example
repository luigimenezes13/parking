NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://parking:parking@localhost:5432/parking
DB_HOST=localhost
DB_PORT=5432
DB_NAME=parking
DB_USER=parking
DB_PASSWORD=parking
DB_MAX_POOL_SIZE=10

# RabbitMQ — fila interna para republicar eventos do /events
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_RECOGNITION_EXCHANGE=recognition.events
RABBITMQ_PREFETCH=10

# Estacionamento default usado pelos handlers de eventos enquanto nao ha CRUD
DEFAULT_PARKING_LOT_ID=00000000-0000-0000-0000-000000000001
