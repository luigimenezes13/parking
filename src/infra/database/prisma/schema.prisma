generator client {
  provider = "prisma-client-js"
}

generator kysely {
  provider     = "prisma-kysely"
  output       = "../types"
  fileName     = "Types.ts"
  enumFileName = "Enums.ts"
}

datasource db {
  provider = "postgresql"
}

enum SpotStatus {
  FREE
  OCCUPIED
  RESERVED
}

enum SessionStatus {
  ACTIVE
  FINISHED
}

enum SpotType {
  REGULAR
  COMPACT
  LARGE
  MOTORCYCLE
  ACCESSIBLE
  ELECTRIC
}

model Driver {
  id            String    @id @db.Uuid
  cnh           String    @unique
  name          String
  email         String    @unique
  phone         String
  createdAt     DateTime  @default(now()) @db.Timestamptz(3) @map("created_at")
  updatedAt     DateTime  @updatedAt @db.Timestamptz(3) @map("updated_at")
  deactivatedAt DateTime? @db.Timestamptz(3) @map("deactivated_at")

  vehicles Vehicle[]

  @@map("drivers")
}

model ParkingLot {
  id            String    @id @db.Uuid
  name          String
  address       String
  totalCapacity Int       @map("total_capacity")
  createdAt     DateTime  @default(now()) @db.Timestamptz(3) @map("created_at")
  updatedAt     DateTime  @updatedAt @db.Timestamptz(3) @map("updated_at")
  deactivatedAt DateTime? @db.Timestamptz(3) @map("deactivated_at")

  spots    ParkingSpot[]
  vehicles Vehicle[]
  sessions ParkingSession[]

  @@map("parking_lots")
}

model ParkingSpot {
  id            String     @id @db.Uuid
  parkingLotId  String     @db.Uuid @map("parking_lot_id")
  code          String
  floor         Int
  row           Int        @default(1)
  column        Int        @default(1)
  isCovered     Boolean    @map("is_covered")
  spotType      SpotType   @default(REGULAR) @map("spot_type")
  status        SpotStatus @default(FREE)
  createdAt     DateTime   @default(now()) @db.Timestamptz(3) @map("created_at")
  updatedAt     DateTime   @updatedAt @db.Timestamptz(3) @map("updated_at")
  deactivatedAt DateTime?  @db.Timestamptz(3) @map("deactivated_at")

  parkingLot ParkingLot       @relation(fields: [parkingLotId], references: [id], onDelete: Restrict)
  sessions   ParkingSession[]

  @@unique([parkingLotId, code])
  @@unique([parkingLotId, floor, row, column])
  @@map("parking_spots")
}

model Vehicle {
  id            String    @id @db.Uuid
  driverId      String?   @db.Uuid @map("driver_id")
  parkingLotId  String    @db.Uuid @map("parking_lot_id")
  licensePlate  String    @unique @map("license_plate")
  brand         String?
  model         String?
  color         String?
  createdAt     DateTime  @default(now()) @db.Timestamptz(3) @map("created_at")
  updatedAt     DateTime  @updatedAt @db.Timestamptz(3) @map("updated_at")
  deactivatedAt DateTime? @db.Timestamptz(3) @map("deactivated_at")

  driver     Driver?          @relation(fields: [driverId], references: [id], onDelete: SetNull)
  parkingLot ParkingLot       @relation(fields: [parkingLotId], references: [id], onDelete: Restrict)
  sessions   ParkingSession[]

  @@map("vehicles")
}

model ParkingSession {
  id             String        @id @db.Uuid
  parkingLotId   String        @db.Uuid @map("parking_lot_id")
  vehicleId      String?       @db.Uuid @map("vehicle_id")
  spotId         String?       @db.Uuid @map("spot_id")
  status         SessionStatus @default(ACTIVE)
  entryAt        DateTime      @db.Timestamptz(3) @map("entry_at")
  spotReleasedAt DateTime?     @db.Timestamptz(3) @map("spot_released_at")
  exitAt         DateTime?     @db.Timestamptz(3) @map("exit_at")
  createdAt      DateTime      @default(now()) @db.Timestamptz(3) @map("created_at")
  updatedAt      DateTime      @updatedAt @db.Timestamptz(3) @map("updated_at")

  parkingLot ParkingLot   @relation(fields: [parkingLotId], references: [id], onDelete: Restrict)
  vehicle    Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  spot       ParkingSpot? @relation(fields: [spotId], references: [id], onDelete: SetNull)

  @@index([parkingLotId, status, vehicleId])
  @@index([parkingLotId, status, entryAt(sort: Asc)], map: "parking_sessions_pending_idx")
  @@index([vehicleId, status])
  @@index([spotId, status])
  @@map("parking_sessions")
}
